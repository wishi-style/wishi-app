model Order {
  id                 String      @id @default(cuid())
  userId             String      @map("user_id")
  sessionId          String?     @map("session_id")
  source             OrderSource
  status             OrderStatus @default(PENDING)
  retailer           String
  totalInCents       Int         @default(0) @map("total_in_cents")
  taxInCents         Int         @default(0) @map("tax_in_cents")
  shippingInCents    Int         @default(0) @map("shipping_in_cents")
  isPriorityShipping Boolean     @default(false) @map("is_priority_shipping")
  commissionInCents  Int?        @map("commission_in_cents")
  orderReference     String?     @map("order_reference")
  currency           String      @default("usd")

  // Shipping + tracking (direct-sale fulfillment)
  trackingNumber      String?   @map("tracking_number")
  carrier             String?
  estimatedDeliveryAt DateTime? @map("estimated_delivery_at")
  shippedAt           DateTime? @map("shipped_at")
  arrivedAt           DateTime? @map("arrived_at")
  customerTeamNotes   String?   @map("customer_team_notes") @db.Text

  // Returns + refunds
  returnInitiatedAt DateTime? @map("return_initiated_at")
  returnedAt        DateTime? @map("returned_at")
  refundedAt        DateTime? @map("refunded_at")
  refundedInCents   Int?      @map("refunded_in_cents")

  // Stripe (direct-sale)
  stripeCheckoutSessionId String? @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String? @unique @map("stripe_payment_intent_id")

  // Shipping address snapshot (denormalized from Stripe Checkout response)
  shippingName       String? @map("shipping_name")
  shippingLine1      String? @map("shipping_line1")
  shippingLine2      String? @map("shipping_line2")
  shippingCity       String? @map("shipping_city")
  shippingState      String? @map("shipping_state")
  shippingPostalCode String? @map("shipping_postal_code")
  shippingCountry    String? @map("shipping_country")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session         Session?         @relation(fields: [sessionId], references: [id])
  items           OrderItem[]
  affiliateClicks AffiliateClick[]

  @@index([userId])
  @@index([sessionId])
  @@index([source])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
  @@index([orderReference])
  // Phase 11: EasyPost webhook looks up orders by tracking number to auto-advance status
  @@index([trackingNumber])
  @@map("orders")
}

