model Board {
  id                  String       @id @default(cuid())
  type                BoardType
  sessionId           String?      @map("session_id")
  stylistProfileId    String?      @map("stylist_profile_id")
  isFeaturedOnProfile Boolean      @default(false) @map("is_featured_on_profile")
  profileStyle        String?      @map("profile_style")
  parentBoardId       String?      @map("parent_board_id")
  isRevision          Boolean      @default(false) @map("is_revision")
  title               String?
  stylistNote         String?      @map("stylist_note") @db.Text
  // Phase 12: styleboard save dialog collects a description + tags alongside the title.
  description         String?      @db.Text
  tags                String[]     @default([])
  sentAt              DateTime?    @map("sent_at")
  rating              BoardRating?
  feedbackText        String?      @map("feedback_text") @db.Text
  ratedAt             DateTime?    @map("rated_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  session        Session?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  stylistProfile StylistProfile? @relation("StylistProfileBoards", fields: [stylistProfileId], references: [id], onDelete: SetNull)
  parentBoard    Board?          @relation("BoardRevisions", fields: [parentBoardId], references: [id], onDelete: SetNull)
  revisions      Board[]         @relation("BoardRevisions")
  photos         BoardPhoto[]
  items          BoardItem[]
  messages       Message[]
  favoritedBy    FavoriteBoard[]
  featuredFor    StylistProfile? @relation("StylistProfileMoodboard")

  @@index([sessionId, type, sentAt])
  @@index([stylistProfileId, isFeaturedOnProfile, profileStyle])
  @@index([parentBoardId])
  // Phase 11: public /feed query ranges across all stylists' featured styleboards ordered by createdAt desc
  @@index([type, isFeaturedOnProfile, createdAt(sort: Desc)])
  @@map("boards")
}

model BoardItem {
  id                  String          @id @default(cuid())
  boardId             String          @map("board_id")
  source              BoardItemSource
  orderIndex          Int             @default(0) @map("order_index")
  inventoryProductId  String?         @map("inventory_product_id")
  closetItemId        String?         @map("closet_item_id")
  inspirationPhotoId  String?         @map("inspiration_photo_id")
  webItemUrl          String?         @map("web_item_url")
  webItemTitle        String?         @map("web_item_title")
  webItemBrand        String?         @map("web_item_brand")
  webItemPriceInCents Int?            @map("web_item_price_in_cents")
  webItemImageUrl     String?         @map("web_item_image_url")
  // Phase 12: LookCreator canvas — stylists position each item on a 2-D
  // composition surface. x/y are canvas coordinates (pixels, 0-based),
  // zIndex is the stacking order. flipH/V mirror the image; crop fields
  // are percent insets (0–100) from each edge. Null on moodboard items +
  // legacy rows; the client-side viewer ignores them.
  x                   Float?
  y                   Float?
  zIndex              Int?            @map("z_index")
  flipH               Boolean         @default(false) @map("flip_h")
  flipV               Boolean         @default(false) @map("flip_v")
  cropTop             Float?          @map("crop_top")
  cropRight           Float?          @map("crop_right")
  cropBottom          Float?          @map("crop_bottom")
  cropLeft            Float?          @map("crop_left")
  reaction            BoardRating?
  feedbackText        String?         @map("feedback_text") @db.Text
  suggestedFeedback   String[]        @map("suggested_feedback")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  board            Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  closetItem       ClosetItem?       @relation(fields: [closetItemId], references: [id], onDelete: SetNull)
  inspirationPhoto InspirationPhoto? @relation(fields: [inspirationPhotoId], references: [id], onDelete: SetNull)

  @@index([boardId, orderIndex])
  @@index([closetItemId])
  @@index([inspirationPhotoId])
  @@index([inventoryProductId])
  @@map("board_items")
}

