  webItemBrand        String?  @map("web_item_brand")
  webItemImageUrl     String?  @map("web_item_image_url")
  webItemPriceInCents Int?     @map("web_item_price_in_cents")
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, inventoryProductId])
  @@map("favorite_items")
}

model FavoriteBoard {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  boardId   String   @map("board_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
  @@index([userId])
  @@map("favorite_boards")
}

model Collection {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  name          String
  coverImageUrl String?  @map("cover_image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@index([userId, createdAt])
  @@map("collections")
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String   @map("collection_id")
  closetItemId String   @map("closet_item_id")
  sortOrder    Int      @default(0) @map("sort_order")
  addedAt      DateTime @default(now()) @map("added_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  closetItem ClosetItem @relation(fields: [closetItemId], references: [id], onDelete: Cascade)

  @@unique([collectionId, closetItemId])
  @@index([collectionId, sortOrder])
  @@index([closetItemId])
  @@map("collection_items")
}

// ─── Domain 9: Admin ──────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  meta        Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model AdminImpersonation {
  id           String    @id @default(cuid())
  adminUserId  String    @map("admin_user_id")
  targetUserId String    @map("target_user_id")
  reason       String
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")

  @@index([adminUserId, startedAt])
  @@index([targetUserId, startedAt])
  @@map("admin_impersonations")
}
