{
  "name": "wishi-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "E2E_AUTH_MODE=true next dev --hostname 0.0.0.0 --port 3001",
    "build:e2e": "E2E_AUTH_MODE=true next build",
    "build": "next build",
    "start": "next start",
    "start:e2e": "npm run build:e2e && npm run start:e2e:prebuilt",
    "start:e2e:prebuilt": "cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public 2>/dev/null; E2E_AUTH_MODE=true HOSTNAME=0.0.0.0 PORT=3001 node .next/standalone/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "test:visual:stylist": "playwright test --config=playwright.visual-stylist.config.ts",
    "test:visual:stylist:update": "playwright test --config=playwright.visual-stylist.config.ts --update-snapshots",
    "test:visual:client": "playwright test --config=playwright.visual-client.config.ts",
    "test:visual:client:update": "playwright test --config=playwright.visual-client.config.ts --update-snapshots",
    "test:load": "k6 run tests/load/marketing.js",
    "test:load:feed": "k6 run tests/load/feed-api.js",
    "test:load:checkout": "k6 run tests/load/checkout-burst.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@base-ui/react": "^1.4.0",
    "@clerk/nextjs": "^7.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@tanstack/react-table": "^8.21.3",
    "@twilio/conversations": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "twilio": "^5.13.1",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
