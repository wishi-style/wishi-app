# Database (RDS Postgres via RDS Proxy)
DATABASE_URL="postgresql://wishi:password@localhost:5432/wishi"
DIRECT_DATABASE_URL="postgresql://wishi:password@localhost:5432/wishi"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Twilio Conversations
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_API_KEY_SID=SKxxx
TWILIO_API_KEY_SECRET=xxx
TWILIO_CONVERSATIONS_SERVICE_SID=ISxxx
# For local dev: set to your ngrok URL so signature verification doesn't depend
# on header forwarding. Configure your Twilio Conversations Service webhook to
# this same URL. Leave unset in deployed envs (the route reconstructs from
# X-Forwarded-* headers behind ALB).
# TWILIO_WEBHOOK_URL=https://your-tunnel.ngrok-free.dev/api/webhooks/twilio

# Web Push (VAPID)
VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx

# Klaviyo (transactional email via Events API + Flows)
# API key from https://www.klaviyo.com/account#api-keys-tab (private API key, not public).
# When unset, the dispatcher skips email fan-out silently — local dev works
# without a key; staging/prod pull from Secrets Manager at wishi/<env>/klaviyo/api_key.
KLAVIYO_API_KEY=pk_xxx
# Optional: pin the Klaviyo API revision. Defaults to 2024-10-15.
# KLAVIYO_REVISION=2024-10-15

# EasyPost (carrier tracking — Phase 11)
# Private API key. When unset, admin tracking input still persists the
# number but no EasyPost tracker is created, so no webhook-driven status
# auto-advance runs. Staging/prod pull from Secrets Manager.
EASYPOST_API_KEY=EZAK_xxx
# HMAC signing secret for inbound webhooks. Must be set in deployed envs —
# the webhook route returns 500 when this is unset.
EASYPOST_WEBHOOK_SECRET=xxx

# AWS S3
S3_UPLOADS_BUCKET=wishi-uploads-staging
AWS_REGION=us-east-1

# Tastegraph Inventory Service (product catalog)
# Leave unset to disable inventory integration — the board builder's Inventory
# tab will render an empty state rather than error.
# Staging ALB is public; no auth. Local dev runs at http://localhost:3001
# (note: collides with `npm run dev:e2e` which also uses 3001).
INVENTORY_SERVICE_URL=https://inventory.stg.mira.prepx.ai

# App
APP_URL=http://localhost:3000

# Phase 10 feature flags
# Stylist chat "Suggested Replies" chip row. Off by default until Phase 7 ships
# real AI-generated replies. When false, the chip row is not rendered.
NEXT_PUBLIC_FEATURE_AI_SUGGESTED_REPLIES=false
